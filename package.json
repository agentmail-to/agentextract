{
  "name": "agentextract",
  "version": "0.1.1",
  "description": "Email quote & signature extractor — strips quoted history and boilerplate, keeping the sender's new content. Pure regex: no DOM parser, no ML.",
  "license": "MIT",
  "author": {
    "name": "AgentMail",
    "url": "https://www.agentmail.to"
  },
  "homepage": "https://github.com/agentmail-to/agentextract#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentmail-to/agentextract.git"
  },
  "bugs": {
    "url": "https://github.com/agentmail-to/agentextract/issues"
  },
  "keywords": [
    "email",
    "quote",
    "signature",
    "reply",
    "quoted-text",
    "extract",
    "quotation",
    "talon",
    "text",
    "html"
  ],
  "type": "commonjs",
  "main": "dist/agentextract.js",
  "types": "dist/agentextract.d.ts",
  "exports": {
    ".": {
      "types": "./dist/agentextract.d.ts",
      "default": "./dist/agentextract.js"
    },
    "./attachments": {
      "types": "./dist/attachextract.d.ts",
      "default": "./dist/attachextract.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run test"
  },
  "devDependencies": {
    "@types/html-to-text": "^9.0.4",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "html-to-text": "^10.0.0",
    "iconv-lite": "^0.7.2",
    "jschardet": "^3.1.4",
    "mailparser": "^3.9.12",
    "mammoth": "^1.12.0",
    "unpdf": "^1.6.2"
  }
}
